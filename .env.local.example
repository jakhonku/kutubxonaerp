# Supabase — Project Settings > API bo'limidan oling
# DIQQAT: Bu yerga HAQIQIY kalitlarni yozmang. Haqiqiy qiymatlar faqat
# .env.local faylida bo'lishi kerak (u .gitignore orqali git'ga tushmaydi).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — FAQAT server tomonida (RLS aylanib o'tadi). Hech qachon clientga chiqarmang!
# Bu kalit bazaga to'liq admin huquqi beradi — hech qachon commit qilmang.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
